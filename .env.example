# ==============================
# Canvas Basic Configuration (Required)
# ==============================
CANVAS_URL=https://canvas.example.edu
CANVAS_TOKEN=your_canvas_token_here
COURSE_ID=12345
ASSIGNMENT_ID=67890

# ==============================
# LLM (AI Model) Configuration (Recommended: OpenAI or compatible)
# ==============================
LLM_PROVIDER=auto
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1

# Azure OpenAI (Optional - uncomment if using Azure)
# LLM_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_API_VERSION=2024-06-01

# Model names (we can change later)
VISION_MODEL=gpt-4o-mini
GRADING_MODEL=gpt-4o-mini

# Folder paths (the program will create these folders automatically)
DOWNLOAD_DIR=./student_submissions
RESULTS_DIR=./Results
ANSWER_DIR=./Answer

# Deduction rules (AI will follow this when grading)
DEDUCTION_RULES="Total score 100 points. Normal scores should be 85-100. \
Major omissions or critical errors can deduct to 70. \
Correct answer = 0 deduction; \
Wrong answer but good steps = 1-2 deduction; \
Wrong answer with no steps = 3-4 deduction."

# Whether to return comments back to Canvas (set to false for now)
RETURN_COMMENT_TO_CANVAS=false
TOTAL_QUESTIONS=